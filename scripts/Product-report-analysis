/*
==================================================
Product Report
==================================================
purpose:
   -This report consolidate key product metrics and behaviours.

 Higlights:
   1. Gathers essentials feild such as  product name ,category, subcategory and cost.
   2.segement product by revenue to identify High-prformers, mid-range, or low-performers.
   3.Aggregates product-level metrics:
      -total orders
	  -total sales
	  -total quantity
	  -total customers(unique)
	  -lifespan (in months)
	4.calculate valuable kpi:
	  -recency (month since last sale)
	  -average order revenue(aor)
	  -average monthly revenue
================================================================================
*/ 

create view gold.report_products as
with base_query as(
select 
p.product_key,
p.Product_name,
p.category,
p.subcategory,
p.cost,
f.order_number,
f.order_date,
f.customer_key,
f.sales_amount,
f.quantity
from 
gold.fact_sales f
left join gold.dim_products p
on f.product_key = p.product_key 
),
product_aggregation as(
select
product_key,
Product_name,
category,
subcategory,
 --(EXTRACT(year FROM AGE(MAX(f.order_date), MIN(f.order_date))) * 12) + 
     EXTRACT(month FROM AGE(MAX(order_date), MIN(order_date))) AS lifespan_months,
	max(order_date) as last_sale_date,
count(distinct order_number) as total_order,
count(distinct customer_key) as total_customer,
sum(sales_amount) as total_sales,
sum(quantity) as total_quantity,
round(avg(sales_amount/quantity),0) as avg_selling_price
from base_query
group by product_key,
product_name,
category,
subcategory
)

select
product_key,
product_name,
category,
subcategory,
last_sale_date,
extract(month from age(current_date,last_sale_date)) as recency,
 case when total_sales > 5000 then 'High performer'
 when total_sales > 1000 then 'mid  range'
 else 'low-performer'
end as product_segement,
lifespan_months,
total_order,
total_sales,
total_quantity,
total_customer,
avg_selling_price,
case when total_order =0 then 0
else total_sales / total_order
end as avg_order_revenue,

round(case when lifespan_months = 0 then 0
else total_sales /lifespan_months
end,0) as avg_monthly_revenue
from product_aggregation
